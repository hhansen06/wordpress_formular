    /**
     * Verarbeitet Formular-Submission
     */
    public function handle_form_submission()
    {
        check_ajax_referer('form_builder_submit_nonce', 'nonce');

        global $wpdb;
        $form_id = intval($_POST['form_id']);

        // Hole Formular-Definition
        $form = $wpdb->get_row($wpdb->prepare(
            "SELECT * FROM {$wpdb->prefix}form_builder_forms WHERE id = %d",
            $form_id
        ), ARRAY_A);

        if (!$form) {
            wp_send_json_error(array('message' => 'Formular nicht gefunden.'));
        }

        // Anti-Spam-Prüfungen
        $settings = json_decode($form['settings'], true);
        $current_lang = $this->resolve_form_language($settings);

        // Honeypot-Prüfung
        if (!empty($settings['honeypot_enabled']) && !empty($_POST['website_url'])) {
            wp_send_json_error(array('message' => 'Spam erkannt.'));
        }

        // CAPTCHA-Prüfung
        if (!empty($settings['enable_captcha'])) {
            $captcha_answer = isset($_POST['captcha_answer']) ? intval($_POST['captcha_answer']) : 0;
            $captcha_num1 = isset($_POST['captcha_num1']) ? intval($_POST['captcha_num1']) : 0;
            $captcha_num2 = isset($_POST['captcha_num2']) ? intval($_POST['captcha_num2']) : 0;
            $captcha_hash = isset($_POST['captcha_hash']) ? sanitize_text_field($_POST['captcha_hash']) : '';

            $expected_hash = md5($captcha_num1 . '+' . $captcha_num2 . NONCE_SALT);
            $expected_answer = $captcha_num1 + $captcha_num2;

            if ($captcha_hash !== $expected_hash || $captcha_answer !== $expected_answer) {
                $captcha_error = $this->get_translated_setting(
                    $settings,
                    'captcha_error_message',
                    $current_lang,
                    'Falsche CAPTCHA-Antwort. Bitte versuchen Sie es erneut.'
                );
                wp_send_json_error(array('message' => $captcha_error));
            }
        }

        $fields = json_decode($form['fields'], true);
        $form_data = array();
        $errors = array();
        $attachments = array();

        // Validiere Felder
        foreach ($fields as $field) {
            // Überspringe Felder ohne Eingabe (heading, text_info, image)
            if (in_array($field['type'], array('heading', 'text_info', 'image'))) {
                continue;
            }

            $field_name = 'field_' . $field['id'];
            $value = isset($_POST[$field_name]) ? $_POST[$field_name] : '';
            $field_label = $this->get_translated_field_value($field, 'label', $current_lang, $field['label'] ?? 'Feld');

            // Erforderliche Felder prüfen
            if (!empty($field['required']) && empty($value)) {
                $errors[] = $field_label . ' ist erforderlich.';
                continue;
            }

            // Sanitize basierend auf Feldtyp
            switch ($field['type']) {
                case 'signature':
                    $value = is_string($value) ? trim($value) : '';
                    if ($value !== '') {
                        $signature = $this->save_signature_image($value, $form_id, $field['id']);
                        if (!$signature) {
                            $errors[] = $field_label . ' konnte nicht gespeichert werden.';
                            break;
                        }
                        $value = $signature['url'];
                        $attachments[] = $signature['path'];
                    }
                    break;
                case 'email':
                    $value = sanitize_email($value);
                    if (!empty($value) && !is_email($value)) {
                        $errors[] = $field_label . ' ist keine gültige E-Mail-Adresse.';
                    }
                    break;
                case 'url':
                    $value = esc_url_raw($value);
                    break;
                case 'textarea':
                    $value = sanitize_textarea_field($value);
                    break;
                case 'checkbox_group':
                    if (is_array($value)) {
                        $value = array_map('sanitize_text_field', $value);
                        $value = array_filter($value, function ($item) {
                            return $item !== '';
                        });
                        // Array-Keys neu indizieren nach Filter
                        $value = array_values($value);
                    } elseif (is_string($value) && !empty($value)) {
                        // Fallback: Wenn als String gesendet wurde (sollte nicht passieren)
                        // Behandle es als einzelnen Wert
                        $value = array(sanitize_text_field($value));
                    } else {
                        $value = array();
                    }
                    error_log('Checkbox group value for ' . $field_label . ': ' . print_r($value, true));
                    break;
                case 'checkbox':
                    $value = !empty($value) ? '1' : '0';
                    break;
                default:
                    $value = sanitize_text_field($value);
            }

            $form_data[$field_label] = $value;
        }

        if (!empty($errors)) {
            wp_send_json_error(array('message' => implode('<br>', $errors)));
        }

        // Debug: Log form_data before saving
        error_log('Form data to save: ' . print_r($form_data, true));
        error_log('Form data JSON: ' . json_encode($form_data));

        // Speichere Submission
        $wpdb->insert(
            $wpdb->prefix . 'form_builder_submissions',
            array(
                'form_id' => $form_id,
                'data' => json_encode($form_data),
                'user_ip' => $_SERVER['REMOTE_ADDR'],
                'user_agent' => $_SERVER['HTTP_USER_AGENT'],
            )
        );

        // E-Mail-Benachrichtigung senden
        if (!empty($settings['enable_email_notification'])) {
            $this->send_email_notification($form, $form_data, $settings, $attachments);
        }

        // Bestätigungsmail an Benutzer senden
        if (!empty($settings['enable_user_confirmation'])) {
            $this->send_user_confirmation($form, $form_data, $settings, $fields);
        }

        $success_message = $this->get_translated_setting(
            $settings,
            'success_message',
            $current_lang,
            'Formular erfolgreich gesendet!'
        );

        wp_send_json_success(array('message' => $success_message));
    }

    /**
     * Sendet E-Mail-Benachrichtigung bei Formular-Einreichung
     */
    private function send_email_notification($form, $form_data, $settings, $attachments = array())
    {
        $to = !empty($settings['notification_email']) ? $settings['notification_email'] : get_option('admin_email');

        // Verarbeite mehrere E-Mail-Adressen
        $recipients = array_map('trim', explode(',', $to));
        $recipients = array_filter($recipients, 'is_email');

        if (empty($recipients)) {
            return;
        }

        $subject = !empty($settings['notification_subject']) ? $settings['notification_subject'] : 'Neuer Formulareintrag: ' . $form['name'];

        // Ersetze Platzhalter im Betreff
        $subject = str_replace('{form_name}', $form['name'], $subject);
        $subject = str_replace('{date}', date_i18n(get_option('date_format') . ' ' . get_option('time_format')), $subject);

        // E-Mail-Header
        $headers = array('Content-Type: text/html; charset=UTF-8');

        if (!empty($settings['notification_from_name']) && !empty($settings['notification_from_email'])) {
            $from_name = sanitize_text_field($settings['notification_from_name']);
            $from_email = sanitize_email($settings['notification_from_email']);
            $headers[] = "From: {$from_name} <{$from_email}>";
        }

        // E-Mail-Body
        $message = '<html><body>';
        $message .= '<h2>Neuer Formulareintrag: ' . esc_html($form['name']) . '</h2>';
        $message .= '<p><strong>Datum:</strong> ' . date_i18n(get_option('date_format') . ' ' . get_option('time_format')) . '</p>';
        $message .= '<table style="border-collapse: collapse; width: 100%;">';

        foreach ($form_data as $label => $value) {
            if (is_array($value)) {
                $value = implode(', ', $value);
            }
            $message .= '<tr>';
            $message .= '<td style="border: 1px solid #ddd; padding: 8px; background-color: #f2f2f2;"><strong>' . esc_html($label) . '</strong></td>';
            $message .= '<td style="border: 1px solid #ddd; padding: 8px;">' . nl2br(esc_html($value)) . '</td>';
            $message .= '</tr>';
        }

        $message .= '</table>';
        $message .= '<p style="margin-top: 20px; color: #666; font-size: 12px;">Diese E-Mail wurde automatisch generiert. Bitte nicht antworten.</p>';
        $message .= '</body></html>';

        // Sende an alle Empfänger
        foreach ($recipients as $recipient) {
            wp_mail($recipient, $subject, $message, $headers, $attachments);
        }
    }

    /**
     * Sendet Bestätigungsmail an den Benutzer
     */
    private function send_user_confirmation($form, $form_data, $settings, $fields)
    {
        // Finde das E-Mail-Feld
        if (empty($settings['user_email_field'])) {
            return;
        }

        $user_email = null;
        foreach ($fields as $field) {
            $field_name = 'field_' . $field['id'];
            if ($field_name === $settings['user_email_field'] && !empty($_POST[$field_name])) {
                $raw_email = $_POST[$field_name];
                $user_email = sanitize_email($raw_email);
                break;
            }
        }

        if (empty($user_email) || !is_email($user_email)) {
            return;
        }

        $current_lang = $this->resolve_form_language($settings);

        $subject = $this->get_translated_setting(
            $settings,
            'user_confirmation_subject',
            $current_lang,
            'Vielen Dank für Ihre Nachricht'
        );
        $message_body = $this->get_translated_setting(
            $settings,
            'user_confirmation_message',
            $current_lang,
            'Vielen Dank für Ihre Nachricht!'
        );

        // Ersetze Platzhalter
        $placeholders = array(
            '{form_name}' => $form['name'],
            '{date}' => date_i18n(get_option('date_format')),
            '{time}' => date_i18n(get_option('time_format')),
        );

        // Füge Feldplatzhalter hinzu: {field_SLUG}
        foreach ($fields as $field) {
            // Überspringe Felder ohne Eingabe
            if (in_array($field['type'], array('heading', 'text_info', 'image'))) {
                continue;
            }

            $field_name = 'field_' . $field['id'];
            $value = isset($_POST[$field_name]) ? $_POST[$field_name] : '';

            if (is_array($value)) {
                $value = implode(', ', $value);
            } else {
                $value = (string) $value;
            }

            // Verwende den Slug als Platzhalter-Key
            $slug = !empty($field['slug']) ? $field['slug'] : sanitize_title($field['label'] ?? '');
            if (!empty($slug)) {
                $placeholders['{field_' . $slug . '}'] = $value;
            }
        }

        // Ersetze Platzhalter in Betreff und Nachricht
        foreach ($placeholders as $placeholder => $value) {
            $subject = str_replace($placeholder, $value, $subject);
            $message_body = str_replace($placeholder, $value, $message_body);
        }

        // E-Mail-Header
        $headers = array('Content-Type: text/html; charset=UTF-8');

        if (!empty($settings['notification_from_name']) && !empty($settings['notification_from_email'])) {
            $from_name = sanitize_text_field($settings['notification_from_name']);
            $from_email = sanitize_email($settings['notification_from_email']);
            $headers[] = "From: {$from_name} <{$from_email}>";
        }

        // E-Mail-Body
        $message = '<html><body>';
        $message .= '<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">';
        $message .= wpautop(wp_kses_post($message_body));
        $message .= '</div>';
        $message .= '</body></html>';

        wp_mail($user_email, $subject, $message, $headers);
    }

    /**
     * Resolves active language for this form, constrained to form languages.
     */
    private function resolve_form_language($settings)
    {
        $current_lang = form_builder_get_current_language_code();
        $form_languages = $this->get_form_languages_from_settings($settings);

        if (!in_array($current_lang, $form_languages, true)) {
            $default_lang = !empty($settings['default_language'])
                ? sanitize_key($settings['default_language'])
                : form_builder_get_default_language_code();

            $current_lang = in_array($default_lang, $form_languages, true)
                ? $default_lang
                : $form_languages[0];
        }

        return $current_lang;
    }

    /**
     * Returns normalized form language list.
     */
    private function get_form_languages_from_settings($settings)
    {
        $default = form_builder_get_default_language_code();

        if (empty($settings['languages'])) {
            return array($default);
        }

        $langs = is_array($settings['languages']) ? $settings['languages'] : array($settings['languages']);
        $langs = array_map('sanitize_key', $langs);
        $langs = array_values(array_filter($langs));

        if (empty($langs)) {
            return array($default);
        }

        $available_codes = array_keys(form_builder_get_available_languages());
        $matching = array_values(array_intersect($langs, $available_codes));

        // Keep legacy forms stable: if none match current multilang config,
        // keep stored values instead of dropping them.
        return !empty($matching) ? $matching : $langs;
    }

    /**
     * Reads translated setting value with fallback to base key.
     */
    private function get_translated_setting($settings, $key, $lang, $default = '')
    {
        $lang_key = $key . '_' . sanitize_key($lang);
        if (!empty($settings[$lang_key])) {
            return $settings[$lang_key];
        }

        $default_lang = !empty($settings['default_language'])
            ? sanitize_key($settings['default_language'])
            : form_builder_get_default_language_code();
        $default_lang_key = $key . '_' . $default_lang;
        if (!empty($settings[$default_lang_key])) {
            return $settings[$default_lang_key];
        }

        if (!empty($settings[$key])) {
            return $settings[$key];
        }
        return $default;
    }

    /**
     * Reads translated field value with fallback to base key.
     */
    private function get_translated_field_value($field, $key, $lang, $default = '')
    {
        $lang_key = $key . '_' . sanitize_key($lang);
        if (!empty($field[$lang_key])) {
            return $field[$lang_key];
        }
        if (!empty($field[$key])) {
            return $field[$key];
        }
        return $default;
    }

    /**
     * Speichert Base64-Unterschrift als PNG
     */
    private function save_signature_image($data_url, $form_id, $field_id)
    {
        if (!is_string($data_url) || strpos($data_url, 'data:image/png;base64,') !== 0) {
            return false;
        }

        $base64 = substr($data_url, strlen('data:image/png;base64,'));
        $binary = base64_decode($base64);
        if ($binary === false) {
            return false;
        }

        $upload_dir = wp_upload_dir();
        $dir = trailingslashit($upload_dir['basedir']) . 'form-builder/signatures';
        if (!wp_mkdir_p($dir)) {
            return false;
        }

        $filename = 'signature_' . intval($form_id) . '_' . sanitize_key($field_id) . '_' . time() . '_' . wp_generate_password(6, false) . '.png';
        $file_path = trailingslashit($dir) . $filename;

        if (file_put_contents($file_path, $binary) === false) {
            return false;
        }

        $file_url = trailingslashit($upload_dir['baseurl']) . 'form-builder/signatures/' . $filename;

        return array(
            'path' => $file_path,
            'url' => $file_url,
        );
    }

    /**
     * Exportiert eine einzelne Submission als PDF
     */
    public function export_submission_pdf()
    {
        if (!current_user_can('manage_options')) {
            wp_die('Keine Berechtigung.');
        }

        check_admin_referer('form_builder_export_pdf');

        $submission_id = isset($_GET['submission_id']) ? intval($_GET['submission_id']) : 0;
        if ($submission_id <= 0) {
            wp_die('Ungültige Submission-ID.');
        }

        global $wpdb;
        $submission = $wpdb->get_row($wpdb->prepare(
            "SELECT s.*, f.name AS form_name, f.fields AS form_fields, f.settings AS form_settings
             FROM {$wpdb->prefix}form_builder_submissions s
             LEFT JOIN {$wpdb->prefix}form_builder_forms f ON s.form_id = f.id
             WHERE s.id = %d",
            $submission_id
        ), ARRAY_A);

        if (!$submission) {
            wp_die('Submission nicht gefunden.');
        }

        $submitted_data = json_decode($submission['data'], true);
        if (!is_array($submitted_data)) {
            $submitted_data = array();
        }

        $form_fields = json_decode($submission['form_fields'], true);
        if (!is_array($form_fields)) {
            $form_fields = array();
        }

        $form_settings = json_decode($submission['form_settings'], true);
        if (!is_array($form_settings)) {
            $form_settings = array();
        }

        // Sprache für Labels bestimmen
        $current_lang = $this->resolve_form_language($form_settings);

        // FPDF laden
        require_once FORM_BUILDER_PLUGIN_DIR . 'lib/fpdf.php';

        // Layout-Konstanten
        $page_width  = 210;
        $margin      = 15;
        $usable_w    = $page_width - $margin * 2; // 180mm
        $col_label   = 60;
        $col_value   = $usable_w - $col_label;    // 120mm

        $pdf = new FPDF();
        $pdf->AddPage();
        $pdf->SetMargins($margin, $margin, $margin);
        $pdf->SetAutoPageBreak(true, $margin);

        // Titel
        $pdf->SetFont('Helvetica', 'B', 16);
        $pdf->SetFillColor(41, 128, 185);
        $pdf->SetTextColor(255, 255, 255);
        $pdf->Cell(0, 10, $this->pdf_encode($submission['form_name']), 0, 1, 'L', true);
        $pdf->Ln(4);

        // Meta-Zeile
        $pdf->SetFont('Helvetica', '', 9);
        $pdf->SetTextColor(120, 120, 120);
        $pdf->SetFillColor(245, 245, 245);
        $date_str = date_i18n(
            get_option('date_format') . ' ' . get_option('time_format'),
            strtotime($submission['created_at'])
        );
        $pdf->Cell(0, 6, $this->pdf_encode('Gesendet am: ' . $date_str . '   |   IP: ' . $submission['user_ip']), 0, 1, 'L', true);
        $pdf->Ln(5);

        $fill = false;
        $this->render_pdf_fields($pdf, $form_fields, $submitted_data, $current_lang, $col_label, $col_value, $fill);

        // Ausgabe als Download — downloaded_at setzen
        $filename = $this->resolve_pdf_filename($form_settings, $form_fields, $submitted_data, $submission_id, $submission['form_name']);
        $wpdb->update(
            $wpdb->prefix . 'form_builder_submissions',
            array('downloaded_at' => current_time('mysql')),
            array('id' => $submission_id)
        );
        $pdf->Output('D', $filename);
        exit;
    }

    /**
     * Markiert eine Submission manuell als heruntergeladen (AJAX, admin-only)
     */
    public function mark_submission_downloaded()
    {
        check_ajax_referer('form_builder_nonce', 'nonce');
        if (!current_user_can('manage_options')) {
            wp_send_json_error(array('message' => 'Keine Berechtigung.'));
        }
        global $wpdb;
        $id    = intval($_POST['submission_id'] ?? 0);
        $reset = !empty($_POST['reset']);
        if ($id <= 0) {
            wp_send_json_error(array('message' => 'Ungültige ID.'));
        }
        $value = $reset ? null : current_time('mysql');
        $wpdb->update(
            $wpdb->prefix . 'form_builder_submissions',
            array('downloaded_at' => $value),
            array('id' => $id)
        );
        wp_send_json_success(array(
            'downloaded_at' => $value
                ? date_i18n(get_option('date_format') . ' ' . get_option('time_format'), strtotime($value))
                : null,
        ));
    }

    /**
     * Exportiert alle nicht-heruntergeladenen Submissions (gefiltert nach form_id) als ZIP
     */
    public function export_submissions_bulk_zip()
    {
        if (!current_user_can('manage_options')) {
            wp_die('Keine Berechtigung.');
        }
        check_admin_referer('form_builder_export_pdf_bulk');

        global $wpdb;

        $filter_form_id  = isset($_GET['form_id']) ? intval($_GET['form_id']) : 0;
        $only_new        = !empty($_GET['only_new']);

        $where = $only_new ? "WHERE s.downloaded_at IS NULL" : "WHERE 1=1";
        if ($filter_form_id > 0) {
            $where .= $wpdb->prepare(" AND s.form_id = %d", $filter_form_id);
        }

        $submissions = $wpdb->get_results(
            "SELECT s.*, f.name AS form_name, f.fields AS form_fields, f.settings AS form_settings
             FROM {$wpdb->prefix}form_builder_submissions s
             LEFT JOIN {$wpdb->prefix}form_builder_forms f ON s.form_id = f.id
             $where
             ORDER BY s.created_at DESC
             LIMIT 200",
            ARRAY_A
        );

        if (empty($submissions)) {
            wp_die('Keine Submissions gefunden.');
        }

        require_once FORM_BUILDER_PLUGIN_DIR . 'lib/fpdf.php';

        $zip_tmp = tempnam(sys_get_temp_dir(), 'fb_bulk_') . '.zip';
        $zip     = new ZipArchive();
        if ($zip->open($zip_tmp, ZipArchive::CREATE) !== true) {
            wp_die('ZIP konnte nicht erstellt werden.');
        }

        $used_names = array();

        foreach ($submissions as $submission) {
            $submitted_data = json_decode($submission['data'], true) ?: array();
            $form_fields    = json_decode($submission['form_fields'], true) ?: array();
            $form_settings  = json_decode($submission['form_settings'], true) ?: array();

            // PDF im Speicher erzeugen
            $pdf_content = $this->build_submission_pdf($submission, $submitted_data, $form_fields, $form_settings);

            // Dateiname
            $filename_base = $this->resolve_pdf_filename($form_settings, $form_fields, $submitted_data, $submission['id'], $submission['form_name']);
            // Duplikate im ZIP vermeiden
            $filename_base = rtrim($filename_base, '.pdf');
            $candidate     = $filename_base . '.pdf';
            $counter       = 1;
            while (isset($used_names[$candidate])) {
                $candidate = $filename_base . '-' . $counter . '.pdf';
                $counter++;
            }
            $used_names[$candidate] = true;

            $zip->addFromString($candidate, $pdf_content);
        }

        $zip->close();

        // downloaded_at für alle exportierten Submissions setzen
        $ids = array_column($submissions, 'id');
        $placeholders = implode(',', array_fill(0, count($ids), '%d'));
        $wpdb->query($wpdb->prepare(
            "UPDATE {$wpdb->prefix}form_builder_submissions SET downloaded_at = %s WHERE id IN ($placeholders)",
            array_merge(array(current_time('mysql')), $ids)
        ));

        $zip_name = 'submissions-' . date('Y-m-d-His') . '.zip';
        header('Content-Type: application/zip');
        header('Content-Disposition: attachment; filename="' . $zip_name . '"');
        header('Content-Length: ' . filesize($zip_tmp));
        readfile($zip_tmp);
        @unlink($zip_tmp);
        exit;
    }

    /**
     * Baut ein PDF für eine Submission und gibt den Inhalt als String zurück.
     * Ausgelagert aus export_submission_pdf() für Wiederverwendung im Bulk-Export.
     */
    private function build_submission_pdf($submission, $submitted_data, $form_fields, $form_settings)
    {
        $current_lang = $this->resolve_form_language($form_settings);

        $page_width = 210;
        $margin     = 15;
        $usable_w   = $page_width - $margin * 2;
        $col_label  = 60;
        $col_value  = $usable_w - $col_label;

        $pdf = new FPDF();
        $pdf->AddPage();
        $pdf->SetMargins($margin, $margin, $margin);
        $pdf->SetAutoPageBreak(true, $margin);

        // Titel
        $pdf->SetFont('Helvetica', 'B', 16);
        $pdf->SetFillColor(41, 128, 185);
        $pdf->SetTextColor(255, 255, 255);
        $pdf->Cell(0, 10, $this->pdf_encode($submission['form_name']), 0, 1, 'L', true);
        $pdf->Ln(4);

        // Meta
        $pdf->SetFont('Helvetica', '', 9);
        $pdf->SetTextColor(120, 120, 120);
        $pdf->SetFillColor(245, 245, 245);
        $date_str = date_i18n(
            get_option('date_format') . ' ' . get_option('time_format'),
            strtotime($submission['created_at'])
        );
        $pdf->Cell(0, 6, $this->pdf_encode('Gesendet am: ' . $date_str . '   |   IP: ' . $submission['user_ip']), 0, 1, 'L', true);
        $pdf->Ln(5);

        $fill = false;
        $this->render_pdf_fields($pdf, $form_fields, $submitted_data, $current_lang, $col_label, $col_value, $fill);

        return $pdf->Output('S');
    }

    /**
     * Rendert alle Formularfelder in ein FPDF-Objekt.
     * Wird von export_submission_pdf() und build_submission_pdf() geteilt.
     */
    private function render_pdf_fields($pdf, $form_fields, $submitted_data, $current_lang, $col_label, $col_value, &$fill)
    {
        foreach ($form_fields as $field) {
            $type = $field['type'] ?? '';

            // --- heading ---
            if ($type === 'heading') {
                $label = $this->get_translated_field_value($field, 'label', $current_lang, $field['label'] ?? '');
                $pdf->Ln(2);
                $pdf->SetFont('Helvetica', 'B', 11);
                $pdf->SetTextColor(41, 128, 185);
                $pdf->SetFillColor(235, 245, 255);
                $pdf->Cell(0, 8, $this->pdf_encode($label), 0, 1, 'L', true);
                $pdf->Ln(2);
                $fill = false;
                continue;
            }

            // --- text_info ---
            if ($type === 'text_info') {
                $label      = $this->get_translated_field_value($field, 'label', $current_lang, $field['label'] ?? '');
                $text_raw   = $this->get_translated_field_value($field, 'text_info', $current_lang, $field['text_info'] ?? '');
                $text_plain = wp_strip_all_tags($text_raw);
                $pdf->Ln(1);
                if (!empty($label)) {
                    $pdf->SetFont('Helvetica', 'B', 9);
                    $pdf->SetTextColor(60, 60, 60);
                    $pdf->SetFillColor(250, 250, 220);
                    $pdf->Cell(0, 7, $this->pdf_encode($label), 0, 1, 'L', true);
                }
                if (!empty($text_plain)) {
                    $pdf->SetFont('Helvetica', 'I', 9);
                    $pdf->SetTextColor(80, 80, 80);
                    $pdf->SetFillColor(255, 255, 240);
                    $pdf->MultiCell(0, 6, $this->pdf_encode($text_plain), 0, 'L', true);
                }
                $pdf->Ln(2);
                continue;
            }

            // --- image ---
            if ($type === 'image') {
                $label     = $this->get_translated_field_value($field, 'label', $current_lang, $field['label'] ?? '');
                $image_url = $field['image_url'] ?? '';
                if (empty($image_url)) {
                    continue;
                }
                $upload_dir = wp_upload_dir();
                $image_path = str_replace($upload_dir['baseurl'], $upload_dir['basedir'], $image_url);
                if (!file_exists($image_path)) {
                    $image_path = str_replace(get_site_url(), ABSPATH, $image_url);
                }
                $tmp_file = null;
                if (!file_exists($image_path)) {
                    $response = wp_remote_get($image_url, array('timeout' => 15, 'sslverify' => false));
                    if (!is_wp_error($response) && wp_remote_retrieve_response_code($response) === 200) {
                        $body         = wp_remote_retrieve_body($response);
                        $content_type = wp_remote_retrieve_header($response, 'content-type');
                        $ext          = strpos($content_type, 'png') !== false ? 'png' : (strpos($content_type, 'gif') !== false ? 'gif' : 'jpg');
                        $tmp_file     = sys_get_temp_dir() . '/fb_img_' . md5($image_url) . '.' . $ext;
                        file_put_contents($tmp_file, $body);
                        $image_path   = $tmp_file;
                    }
                }
                $pdf->Ln(2);
                if (!empty($label)) {
                    $pdf->SetFont('Helvetica', 'B', 9);
                    $pdf->SetTextColor(60, 60, 60);
                    $pdf->SetFillColor(245, 245, 245);
                    $pdf->Cell(0, 7, $this->pdf_encode($label), 0, 1, 'L', true);
                }
                if (file_exists($image_path)) {
                    $img_size = @getimagesize($image_path);
                    $img_w_mm = 100;
                    $img_h_mm = ($img_size && $img_size[0] > 0) ? round($img_w_mm * $img_size[1] / $img_size[0], 2) : 50;
                    $img_x    = $pdf->GetX();
                    $img_y    = $pdf->GetY();
                    $pdf->Image($image_path, $img_x, $img_y, $img_w_mm);
                    $pdf->SetY($img_y + $img_h_mm + 4);
                    if ($tmp_file && file_exists($tmp_file)) {
                        @unlink($tmp_file);
                    }
                } else {
                    $pdf->SetFont('Helvetica', 'I', 8);
                    $pdf->SetTextColor(150, 150, 150);
                    $pdf->Cell(0, 6, $this->pdf_encode('[Bild nicht verfuegbar: ' . $image_url . ']'), 0, 1, 'L');
                }
                $pdf->Ln(2);
                continue;
            }

            // --- Eingabefelder ---
            $field_label = $this->get_translated_field_value($field, 'label', $current_lang, $field['label'] ?? '');
            $value       = $submitted_data[$field_label] ?? $submitted_data[$field['label'] ?? ''] ?? '';
            if (is_array($value)) {
                $value = implode(', ', $value);
            }
            $value = (string) $value;

            // Signatur
            if (strpos($value, '/form-builder/signatures/') !== false) {
                $upload_dir = wp_upload_dir();
                $sig_path   = str_replace($upload_dir['baseurl'], $upload_dir['basedir'], $value);
                $pdf->SetFillColor($fill ? 248 : 255, $fill ? 248 : 255, $fill ? 248 : 255);
                $pdf->SetFont('Helvetica', 'B', 9);
                $pdf->SetTextColor(60, 60, 60);
                $pdf->Cell($col_label, 8, $this->pdf_encode($field_label . ':'), 0, 0, 'L', true);
                $pdf->Cell($col_value, 8, '', 0, 1, 'L', true);
                if (file_exists($sig_path)) {
                    $pdf->Image($sig_path, $pdf->GetX() + $col_label, $pdf->GetY(), 60);
                    $pdf->Ln(22);
                } else {
                    $pdf->SetFont('Helvetica', 'I', 8);
                    $pdf->SetTextColor(150, 150, 150);
                    $pdf->Cell(0, 6, $this->pdf_encode('(Unterschrift vorhanden)'), 0, 1, 'L');
                }
                $fill = !$fill;
                continue;
            }

            // Normale Zeile
            $pdf->SetFillColor($fill ? 248 : 255, $fill ? 248 : 255, $fill ? 248 : 255);
            $fill = !$fill;
            $x   = $pdf->GetX();
            $y   = $pdf->GetY();
            $pdf->SetFont('Helvetica', 'B', 9);
            $pdf->SetTextColor(60, 60, 60);
            $pdf->MultiCell($col_label, 7, $this->pdf_encode($field_label . ':'), 0, 'L', true);
            $label_h = $pdf->GetY() - $y;
            $pdf->SetFont('Helvetica', '', 9);
            $pdf->SetTextColor(40, 40, 40);
            $pdf->SetXY($x + $col_label, $y);
            $pdf->MultiCell($col_value, 7, $this->pdf_encode($value), 0, 'L', true);
            $value_h = $pdf->GetY() - $y;
            if ($label_h > $value_h) {
                $pdf->SetY($y + $label_h);
            }
        }
    }

    private function resolve_pdf_filename($settings, $form_fields, $submitted_data, $submission_id, $form_name)
    {
        $template = !empty($settings['pdf_filename']) ? trim($settings['pdf_filename']) : '';

        if (empty($template)) {
            return 'submission-' . $submission_id . '-' . sanitize_title($form_name) . '.pdf';
        }

        // Slug -> Label-Map aufbauen
        $slug_to_label = array();
        foreach ($form_fields as $field) {
            if (!empty($field['slug'])) {
                $slug_to_label[$field['slug']] = $field['label'] ?? '';
            }
        }

        // Platzhalter ersetzen: {field_SLUG}
        $filename = preg_replace_callback('/\{field_([^}]+)\}/', function ($matches) use ($slug_to_label, $submitted_data) {
            $slug  = $matches[1];
            $label = $slug_to_label[$slug] ?? null;
            $value = '';
            if ($label !== null && isset($submitted_data[$label])) {
                $value = $submitted_data[$label];
            }
            if (is_array($value)) {
                $value = implode('-', $value);
            }
            return sanitize_title((string) $value);
        }, $template);

        // Sonderzeichen bereinigen, .pdf anhängen
        $filename = sanitize_file_name($filename);
        // Leere Segmente durch Bindestriche zusammenführen
        $filename = preg_replace('/-{2,}/', '-', $filename);
        $filename = trim($filename, '-');

        if (empty($filename)) {
            $filename = 'submission-' . $submission_id;
        }

        return $filename . '.pdf';
    }

    /**
     * Konvertiert UTF-8-Text in Latin-1 für FPDF (FPDF unterstützt kein UTF-8 nativ)
     */
    private function pdf_encode($text)
    {
        return iconv('UTF-8', 'ISO-8859-1//TRANSLIT//IGNORE', $text);
    }

    /**
     * Rendert Formular via Shortcode
     */
    public function render_form_shortcode($atts)
    {
        $atts = shortcode_atts(array(
            'id' => 0,
        ), $atts);

        $form_id = intval($atts['id']);

        if ($form_id <= 0) {
            return '<p>Ungültige Formular-ID.</p>';
        }

        global $wpdb;
        $form = $wpdb->get_row($wpdb->prepare(
            "SELECT * FROM {$wpdb->prefix}form_builder_forms WHERE id = %d",
            $form_id
        ), ARRAY_A);

        if (!$form) {
            return '<p>Formular nicht gefunden.</p>';
        }

        $fields = json_decode($form['fields'], true);
        $form['settings'] = json_decode($form['settings'], true);

        ob_start();
        include FORM_BUILDER_PLUGIN_DIR . 'templates/frontend/form.php';
        return ob_get_clean();
    }
